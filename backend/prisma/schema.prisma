generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

enum ReservationStatus {
  ACTIVE
  PENDING
  PURCHASED
  CONFIRMED
  EXPIRED
  CANCELLED
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  username     String        @unique
  reservations Reservation[]
  purchases    Purchase[]

  @@index([username])
}

model Drop {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  totalStock     Int
  availableStock Int
  startTime      DateTime
  stockVersion   Int           @default(0)
  updatedAt      DateTime      @updatedAt
  reservations   Reservation[]
  purchases      Purchase[]

  @@index([startTime])
  @@index([availableStock])
  @@index([startTime, availableStock])
}

model Reservation {
  id        String            @id @default(uuid()) @db.Uuid
  userId    String            @db.Uuid
  dropId    String            @db.Uuid
  status    ReservationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  drop      Drop              @relation(fields: [dropId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dropId])
  @@index([userId, dropId])
  @@index([dropId, status])
  @@index([status, expiresAt])
}

model Purchase {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  dropId    String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  drop      Drop     @relation(fields: [dropId], references: [id], onDelete: Cascade)

  @@unique([userId, dropId])
  @@index([userId])
  @@index([dropId])
  @@index([dropId, createdAt])
}
